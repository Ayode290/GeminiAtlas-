      {}
  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">SceneSwitcherPanel – three-way scene toggler</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Wires three pre-made round toggle buttons. Pressing one enables its group of objects and disables the other two, drives icon opacity, and continuously billboards in front of the camera. Controllable from script via global.sceneSwitcher.activateGroup(i).</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Scene References</span>"}'
    - "// @input SceneObject cameraObj {\"hint\":\"Head camera object (wire the 'Camera Object'). The panel billboards in front of it.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Group 1</span>"}'
    - '// @input SceneObject scene1Button {"hint":"The Scene1 round toggle button object"}'
    - '// @input Asset.Texture scene1IconTexture {"hint":"Icon texture (PNG) shown on the Scene1 button. The script builds the image; its opacity is driven by selection."}'
    - '// @input string scene1Label = "Scene 1" {"hint":"Text shown under the Scene1 button"}'
    - '// @input SceneObject[] scene1Objects = {} {"hint":"Objects/prefabs enabled when Group 1 is active (disabled otherwise)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Group 2</span>"}'
    - '// @input SceneObject scene2Button {"hint":"The Scene2 round toggle button object"}'
    - '// @input Asset.Texture scene2IconTexture {"hint":"Icon texture (PNG) shown on the Scene2 button. The script builds the image; its opacity is driven by selection."}'
    - '// @input string scene2Label = "Scene 2" {"hint":"Text shown under the Scene2 button"}'
    - '// @input SceneObject[] scene2Objects = {} {"hint":"Objects/prefabs enabled when Group 2 is active (disabled otherwise)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Group 3</span>"}'
    - '// @input SceneObject scene3Button {"hint":"The Scene3 round toggle button object"}'
    - '// @input Asset.Texture scene3IconTexture {"hint":"Icon texture (PNG) shown on the Scene3 button. The script builds the image; its opacity is driven by selection."}'
    - '// @input string scene3Label = "Scene 3" {"hint":"Text shown under the Scene3 button"}'
    - '// @input SceneObject[] scene3Objects = {} {"hint":"Objects/prefabs enabled when Group 3 is active (disabled otherwise)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Selection & Icon Appearance</span>"}'
    - '// @input float initialGroup = 1 {"hint":"Group selected on launch (1-3). 0 leaves all groups off until a button is pressed."}'
    - '// @input Asset.Material iconMaterial {"hint":"Unlit, transparency-capable material the icons are drawn with. The script clones it per icon and sets the texture + opacity on the clone."}'
    - "// @input float iconSize = 2 {\"hint\":\"Icon height in cm. Width follows the texture's aspect ratio.\"}"
    - '// @input float iconForwardOffset = 0.2 {"hint":"How far in front of the button face (cm) the icon sits, to avoid clipping"}'
    - "// @input float selectedIconAlpha = 1 {\"hint\":\"Icon opacity (0-1) of the SELECTED scene's button\"}"
    - "// @input float unselectedIconAlpha = 0.35 {\"hint\":\"Icon opacity (0-1) of UNSELECTED scenes' buttons\"}"
    - '// @input float labelOffset = 2.5 {"hint":"How far below each button (cm) the text label sits"}'
    - '// @input float labelForwardOffset = 0.2 {"hint":"How far in front of the button face (cm) the label sits, to avoid clipping"}'
    - '// @input float labelSize = 28 {"hint":"Font size for the button labels"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Camera Tracking</span>"}'
    - '// @input bool enableTracking = true {"hint":"Continuously billboard-follow the camera. Turn off to keep the panel where it is authored."}'
    - '// @input float distanceFromCamera = 60 {"hint":"Distance in cm to keep the panel in front of the camera"}'
    - "// @input float heightOffset {\"hint\":\"Vertical offset in cm from the camera's eye line (positive = higher)\"}"
    - '// @input float followSpeed = 6 {"hint":"Position follow speed (lerp factor = followSpeed * dt). Lower = lazier, laggier follow."}'
    - '// @input float rotateSpeed = 6 {"hint":"Rotation follow speed for the billboard (slerp factor = rotateSpeed * dt)."}'
    - '// @input float positionDeadzone = 5 {"hint":"Dead zone radius in cm: the panel only chases the camera once the target drifts beyond this, killing micro-jitter."}'
    - '// @input float rotationDeadzoneDeg = 0.5 {"hint":"Rotation dead zone in degrees: the panel only re-aims once the target rotation drifts beyond this, so a still/slightly-moving head costs no rotation work. Set 0 to always re-aim."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Right-Palm Attach Mode</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">When ON, the panel ignores camera tracking and instead rides above the right wrist, appearing only while the right palm faces you (the classic raise-your-palm hand-menu gesture). The script keeps running while hidden so the active scene and pose detection are unaffected. In the editor (no hand tracking) it falls back to camera billboard so you can still see it.</span>"}'
    - '// @input bool attachToRightPalm {"hint":"Attach the panel to the right palm (turn your palm toward you to reveal it) instead of billboarding in front of the camera."}'
    - "// @input vec3 palmOffset = {0,8,0} {\"hint\":\"Offset (cm) from the right wrist, in the wrist's local space, where the panel sits. Positive Y lifts it above the open palm.\"}"
    - '// @input float palmFacingMaxAngleDeg = 55 {"hint":"Palm-facing tolerance in degrees: the panel shows while the palm faces you within this angle. Larger = easier to trigger."}'
    - '// @input bool requireFlatPalm {"hint":"Also require the palm to be open/flat (not a fist) before showing."}'
    - '// @input float palmShowHoldFrames = 3 {"hint":"Consecutive palm-facing frames required before the panel appears (debounce against flicker)."}'
    - "// @input float palmHideHoldFrames = 8 {\"hint\":\"Consecutive non-facing frames required before the panel hides (kept higher than show so brief wobbles don't blink it).\"}"
    - '// @input float palmFollowSpeed = 14 {"hint":"Position follow speed while palm-attached (lerp factor = speed * dt). Higher = snappier to the hand."}'
    - '// @input float palmRotateSpeed = 14 {"hint":"Rotation follow speed while palm-attached (slerp factor = speed * dt)."}'
    - '// @input bool palmFaceCamera = true {"hint":"Billboard the palm panel toward the camera (readable text). Turn off to align it to the wrist orientation instead."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'

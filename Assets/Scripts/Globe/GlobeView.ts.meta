  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">GlobeView – rotate-to-aim + scale-to-zoom Earth globe</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Hidden while the holodeck table is up. Aim/zoom/fade are math-driven so the dock handoff lines up by construction.</span>"}'

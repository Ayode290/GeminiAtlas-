    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Component.RenderMeshVisual globeVisual {"hint":"RenderMeshVisual of the sphere. Its material is cloned so fading never mutates the shared asset."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Footprint matching</span>"}'
    - '// @input float globeRadiusCm {"hint":"Sphere radius in cm at scale = 1. Leave at 0 to AUTO-DETECT from the mesh bounding box (recommended). Set > 0 to override."}'
    - '// @input float tableSizeCm = 60 {"hint":"On-screen size in cm of the holodeck table. dockScaleForSpan scales the globe so its L0 footprint roughly matches the table."}'

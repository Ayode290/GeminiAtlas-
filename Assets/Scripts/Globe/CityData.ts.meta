  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">CityData – binds geo bounds to imported map textures</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Assign the generated PNGs (in L0..Ln order) for each city plus the globe base texture. Bounds come from cityBounds.ts.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Globe</span>"}'
    - '// @input Asset.Texture globeBaseTexture {"hint":"Equirectangular base Earth texture for the globe sphere (hand-imported, not generated)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Tokyo LOD textures (L0, L1, L2 in order)</span>"}'
    - '// @input Asset.Texture[] tokyoLevels {"hint":"Generated Tokyo map PNGs, ordered L0 (largest area) to L2 (block level)."}'
    - '// @input Asset.Texture tokyoTransition {"hint":"Generated Tokyo WIDE handoff PNG (Tokyo_L-1.png, 10x L0 area). Used only during the globe<->table dive."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Seattle LOD textures (L0, L1, L2 in order)</span>"}'
    - '// @input Asset.Texture[] seattleLevels {"hint":"Generated Seattle map PNGs, ordered L0 (largest area) to L2 (block level)."}'
    - '// @input Asset.Texture seattleTransition {"hint":"Generated Seattle WIDE handoff PNG (Seattle_L-1.png, 10x L0 area). Used only during the globe<->table dive."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Los Angeles LOD textures (L0, L1, L2 in order)</span>"}'
    - '// @input Asset.Texture[] losAngelesLevels {"hint":"Generated Los Angeles map PNGs, ordered L0 (largest area) to L2 (block level)."}'
    - '// @input Asset.Texture losAngelesTransition {"hint":"Generated Los Angeles WIDE handoff PNG (Los Angeles_L-1.png, 10x L0 area). Used only during the globe<->table dive."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'

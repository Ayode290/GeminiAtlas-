  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Agent Voice (Gemini Live)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Speaks via Gemini Live through the Remote Service Gateway. Says the welcome line a few seconds after launch; speak(text) drives later agent lines. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (drag from the RemoteServiceGatewayExamples prefab)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject from the RemoteServiceGatewayExamples prefab. Enabled on launch so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"The 'DynamicAudioOutput' object from the RemoteServiceGatewayExamples prefab (it carries the AudioComponent + audio-output track that plays the voice).\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Leda" {"widget":"combobox", "values":[{"label":"Leda", "value":"Leda"}, {"label":"Puck", "value":"Puck"}, {"label":"Charon", "value":"Charon"}, {"label":"Kore", "value":"Kore"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - '// @input string messageText = "Welcome back! I found some new places to visit for you -- hope you find some interesting cards there!" {"hint":"Exact line spoken a few seconds after launch", "widget":"text_area"}'
    - '// @input float delaySeconds = 5 {"hint":"Seconds after launch before the welcome line"}'
    - "// @input string instructions = \"You are a text-to-speech voice, not a conversational assistant. Speak the user's message aloud exactly as written -- word for word -- with no additions, omissions, replies, greetings, or commentary. Never react or respond to the content; only read it aloud, in a warm and friendly tone.\" {\"hint\":\"System instruction. The verbatim-narrator prompt makes Gemini read lines exactly instead of chatting back.\", \"widget\":\"text_area\"}"
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix — it's added automatically). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Logging"}'
    - // @input bool enableLogging = true
    - '// @ui {"widget":"group_end"}'

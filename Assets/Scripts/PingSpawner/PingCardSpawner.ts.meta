  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">PingCardSpawner – reveals location-filtered cards on the ping wavefront</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Call spawnWave(origin) (e.g. from PrayerGestureBehavior). Filters cardDeckData by Location, scatters PremadeCard bubbles in a cylinder, and pops each one when the wavefront reaches it.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Asset.ObjectPrefab cardPrefab {"hint":"The PremadeCard prefab, instantiated once per matching card as a child of this object."}'
    - '// @input SceneObject cameraObject {"hint":"Camera the cards billboard toward + use for gaze. Forwarded to each spawned card."}'
    - '// @input AssignableType pingController {"hint":"PingController whose pingSpeed times the reveals so cards appear with the visible wavefront. Optional — falls back to Wavefront Speed Override."}'
    - '// @input Asset.Texture[] placeholderImages {"hint":"Placeholder image textures, assigned to the spawned cards in order (cycled). Fill the real images in later."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Selection</span>"}'
    - '// @input string location = "Seattle" {"hint":"Only cards whose location matches this are spawned (case-insensitive). e.g. \"Seattle\" | \"Los Angeles\" | \"Tokyo\"."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Spawn area (cylindrical pipe around this object)</span>"}'
    - "// @input float minDistance = 80 {\"hint\":\"Minimum horizontal distance (cm) from this object a card can spawn — the pipe's inner wall.\"}"
    - "// @input float maxDistance = 220 {\"hint\":\"Maximum horizontal distance (cm) from this object a card can spawn — the pipe's outer wall.\"}"
    - '// @input float floorHeight = -50 {"hint":"Floor height (cm, local Y) — the bottom of the spawn pipe. May be negative (below the origin)."}'
    - '// @input float ceilingHeight = 100 {"hint":"Ceiling height (cm, local Y) — the top of the spawn pipe."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Wavefront timing</span>"}'
    - '// @input float wavefrontSpeedOverride {"hint":"Override the wavefront speed (cm/s). 0 = read pingSpeed from the linked PingController (recommended so reveals match the visible ping)."}'
    - '// @input float revealOffsetSec {"hint":"Extra seconds added to every reveal time. Nudge to fine-tune cards popping right ON the band vs slightly behind it."}'
    - "// @input float revealPopDuration = 0.5 {\"hint\":\"Seconds of the bubble's pop-in scale animation when it is revealed.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Card behaviour</span>"}'
    - "// @input float imageWidth {\"hint\":\"Displayed image width (cm) for each card; height follows the image aspect. 0 = keep the prefab's authored width.\"}"
    - '// @input float gazeDwellSec = 1 {"hint":"Seconds the player must gaze at a bubble before it expands into a card."}'
    - "// @input float gazeConeAngleDeg = 12 {\"hint\":\"Half-angle (degrees) of the gaze cone that counts as 'looking at' a bubble.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Behaviour</span>"}'
    - '// @input bool allowRespawn {"hint":"Allow a later wave to clear the previous cards and spawn again. Off = the first wave wins and later calls are ignored."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'

    - websocketRequirementsObj: !<reference.SceneObject> 00000000-0000-0000-0000-000000000000
      dynamicAudioOutput: !<MappingBased.AssignableType> 00000000-0000-0000-0000-000000000000
      voice: Charon
      persona: "You are a sassy, quick-witted trivia game-show host, in the spirit of Tom Gleeson or Anne Robinson: confident, fast, lightly roasting the player's play but never cruel. You will be given a single short line to say. Read it OUT LOUD exactly as written -- the same words, in the same order -- adding only your sassy, confident vocal delivery and timing. Do NOT add, remove, rephrase, translate, or explain anything. No stage directions, no quotation marks, no preamble. Just perform the line."
      model: gemini-live-2.5-flash
      enableLogging: true
  ScriptTypes:
    -
      {}
  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #F59E0B;\">Battle Host (Gemini Live)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Sassy trivia-show host for Battle mode. Speaks curated, guardrail-safe lines (and the per-question roast) as the match unfolds. Audio-only, no mic. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (drag from the RemoteServiceGatewayExamples prefab)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject from the RemoteServiceGatewayExamples prefab. Enabled on launch so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"A DynamicAudioOutput object that plays the host voice. Give this its OWN (separate from the other voices) to avoid audio conflicts — duplicate the prefab's DynamicAudioOutput.\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Charon" {"widget":"combobox", "values":[{"label":"Charon", "value":"Charon"}, {"label":"Puck", "value":"Puck"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Leda", "value":"Leda"}, {"label":"Kore", "value":"Kore"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - "// @input string persona = \"You are the VOICE of a sassy trivia game-show host (in the spirit of Tom Gleeson or Anne Robinson) -- a text-to-speech performer, NOT a chat partner. Every message you receive is ONE line of the host's script, and every line is spoken BY the host TO the two players -- it is NEVER addressed to you. Your only job: read that line OUT LOUD word-for-word, in the same order, with confident, sassy delivery. NEVER treat a line as something said to you, NEVER answer or react to it, and NEVER continue a conversation. Do not add, drop, rephrase, translate, or reorder any words. Never say filler like 'what's on your mind', 'that's fair', or 'I tried' -- say ONLY the words of the line. No greetings, no follow-up questions, no quotation marks, no stage directions, no preamble. Just perform the line.\" {\"hint\":\"Host persona / system instruction. The host reads the supplied line VERBATIM with sassy delivery — it never invents or changes words.\", \"widget\":\"text_area\"}"
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix — it's added automatically). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Logging"}'
    - // @input bool enableLogging = true
    - '// @ui {"widget":"group_end"}'

  InputLines:
    - "// @ui {\"widget\":\"label\", \"label\":\"<span style=\\\"color: #60A5FA;\\\">AgentSubtitle – the voice agent's live caption</span><br/><span style=\\\"color: #94A3B8; font-size: 11px;\\\">A world-space Text positioned by AgentSphere and fed by the voice scripts (global.agentSubtitle.pushText). Types out in sync with the voice, max 2 rolling lines.</span>\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Component.Text subtitleText {"hint":"Text component to drive. Leave empty to auto-create one on a child object."}'
    - '// @input Asset.Font font {"hint":"Font for the auto-created Text (ignored if a Text is assigned above with its own font)."}'
    - '// @input vec4 color = {1,1,1,1} {"hint":"Text color."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Layout</span>"}'
    - '// @input float heightScale = 0.8 {"hint":"THE text size knob. Fraction of the orb height: 1 = one line is exactly half the orb height; lower = smaller text. (Font size is fixed internally — it has no visible effect because the text is auto-scaled to this height.)"}'
    - '// @input float sidePadCm = 0.6 {"hint":"Horizontal padding (cm) inset on each side from the available width."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Reveal (typewriter sync)</span>"}'
    - '// @input float minCps = 6 {"hint":"Slowest reveal speed (chars/sec) while the agent is speaking."}'
    - '// @input float maxCps = 55 {"hint":"Fastest reveal speed (chars/sec); caps how quickly a backlog is flushed."}'
    - '// @input float tailCps = 28 {"hint":"Reveal speed (chars/sec) for the tail once the audio has drained."}'
    - '// @input float lingerSeconds = 1.2 {"hint":"Seconds the finished caption lingers before it clears."}'
    - "// @input float silenceWipeSeconds = 5 {\"hint\":\"Backstop: wipe the caption after this many seconds of total agent silence, even if the normal linger clear didn't fire (e.g. a stuck audio schedule).\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - // @input bool enableLogging
